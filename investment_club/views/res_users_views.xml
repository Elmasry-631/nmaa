<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_users_form_inherit_investment_club_access" model="ir.ui.view">
        <field name="name">res.users.form.inherit.investment.club.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="modules" string="Modules">
                    <group>
                        <group string="Investment Club">
                            <field name="investment_club_access"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>


<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

    <!-- ================================================= -->
    <!--                     CONTRACT                      -->
    <!-- ================================================= -->

    <!-- Tree View -->
    <record id="view_sale_contract_tree" model="ir.ui.view">
        <field name="name">sale.contract.tree</field>
        <field name="model">sale.contract</field>
        <field name="arch" type="xml">
            <list string="Contracts">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <field name="contract_date"/>
                <field name="amount_total"/>
                <field name="state" widget="badge"
                   decoration-primary="state == 'draft'"
                   decoration-success="state == 'active'"
                   decoration-warning="state == 'finished'"
                   decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sale_contract_form" model="ir.ui.view">
        <field name="name">sale.contract.form</field>
        <field name="model">sale.contract</field>
        <field name="arch" type="xml">
            <form string="Contract">

                <header>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,active,finished"
                           statusbar_colors="{'draft':'blue','active':'green','finished':'orange','cancelled':'red'}"/>

                    <button name="action_set_active"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_financial_approve"
                            string="Financial Approve"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'confirmed'"/>

                    <button name="action_legal_approve"
                            string="Legal Approve"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'financial_approved'"/>




                    <button name="action_finish"
                            string="Finish"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'finished'"/>


                    <button name="action_reset_to_draft"
                        string="Reset to Draft"
                        type="object"
                        class="btn-danger"
                        invisible="state not in 'confirmed,financial_approved,legal_approved,finished'" />
                        <button name="print_contract_report"
                                type="object"
                                string="Print Contract"
                                class="btn-primary"/>


                </header>

                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="contract_date"/>
                        <field name="partner_id"/>
                        <field name="contract_title_name"/>
                        <field name="contract_template_id"/>
                    </group>

                    <notebook>

                        <page string="Agreement Terms">
                            <field name="agreement_terms"
                                   widget="html"
                                   options="{'sanitize': False}"
                                   style="direction:rtl;"
                                   readonly="1"
                                   groups="base.group_user"/>
                        </page>
                      <page string="notes">
                        <field name="note"/>
                      </page>

                        <page string="Contract Lines" invisible="1">

                            <field name="contract_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                </list>
                            </field>

                            <group>
                                <field name="subtotal_total"
                                       widget="monetary"
                                       readonly="1"/>
                            </group>

                        </page>

                        <page string="Parties">
                            <group>
                                <field name="first_party_name"/>
                                <field name="first_party_signature" widget="signature"/>
                                <field name="second_party_name"/>
                                <field name="second_party_signature" widget="signature"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>


    <!-- ================================================= -->
    <!--                CONTRACT TEMPLATES                 -->
    <!-- ================================================= -->

    <record id="view_contract_template_tree" model="ir.ui.view">
        <field name="name">contract.template.tree</field>
        <field name="model">contract.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_contract_template_form" model="ir.ui.view">
        <field name="name">contract.template.form</field>
        <field name="model">contract.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="content" direction="rtl" class="text-right"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- ================================================= -->
    <!--                  CONTRACT TITLE                   -->
    <!-- ================================================= -->

    <record id="view_contract_title_tree" model="ir.ui.view">
        <field name="name">sale.contract.title.tree</field>
        <field name="model">sale.contract.title</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_contract_title_form" model="ir.ui.view">
        <field name="name">sale.contract.title.form</field>
        <field name="model">sale.contract.title</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- ================================================= -->
    <!--                   SALE ORDER                      -->
    <!-- ================================================= -->

    <!-- Contract Button -->
    <record id="view_order_form_inherit_contract_button" model="ir.ui.view">
        <field name="name">sale.order.contract.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/div[@class='oe_button_box']" position="inside">

                <button name="action_view_contract"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o">

                    <field name="contract_id" invisible="1"/>

                    <div class="o_stat_info">
                        <span>Contract</span>
                    </div>

                </button>

            </xpath>

        </field>
    </record>


    <!-- Contract Template + Title -->
    <record id="view_order_form_inherit_contract_fields" model="ir.ui.view">
        <field name="name">sale.order.contract.fields</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="contract_template_id"/>
                <field name="contract_title_name"/>
            </xpath>

        </field>
    </record>


    <!-- ================================================= -->
    <!--                     ACTIONS                       -->
    <!-- ================================================= -->

    <record id="action_sale_contracts" model="ir.actions.act_window">
        <field name="name">Sale Contracts</field>
        <field name="res_model">sale.contract</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_contract_templates" model="ir.actions.act_window">
        <field name="name">Contract Templates</field>
        <field name="res_model">contract.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_contract_title" model="ir.actions.act_window">
        <field name="name">Contract Titles</field>
        <field name="res_model">sale.contract.title</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ================================================= -->
    <!--                       MENUS                       -->
    <!-- ================================================= -->

    <menuitem id="menu_contract_root"
              name="Contracts"
              sequence="100"
              web_icon="sale_contract_auto,static/description/icon.png"
    />

    <menuitem id="menu_contracts"
              name="Contracts"
              parent="menu_contract_root"
              action="action_sale_contracts"
              sequence="1"/>

    <menuitem id="menu_contract_templates"
              name="Contract Templates"
              parent="menu_contract_root"
              action="action_contract_templates"
              sequence="10"/>

    <menuitem id="menu_contract_titles"
              name="Contract Titles"
              parent="menu_contract_root"
              action="action_contract_title"
              sequence="11"/>

    <menuitem id="menu_contract_customers"
              name="Customers"
              parent="menu_contract_root"
              action="base.action_partner_form"
              sequence="20"/>

</data>
</odoo>
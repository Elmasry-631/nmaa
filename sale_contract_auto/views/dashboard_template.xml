<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="contract_dashboard_template" name="Contract Dashboard">
        <t t-call="web.layout">
            <t t-set="title">Contract Dashboard</t>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"/>

            <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

            <style>
                .dashboard-container { max-width: 1400px; margin: 0 auto; padding: 20px; }
                .stat-card {
                    background: white; border-radius: 12px; padding: 20px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1); text-align: center;
                    border-top: 4px solid; transition: transform 0.2s;
                }
                .stat-card:hover { transform: translateY(-3px); }
                .stat-card .stat-value { font-size: 2.2em; font-weight: bold; margin: 8px 0; }
                .stat-card .stat-label { font-size: 0.9em; color: #666; }
                .stat-primary { border-top-color: #1C5B8B; }
                .stat-success { border-top-color: #28a745; }
                .stat-warning { border-top-color: #ffc107; }
                .stat-danger { border-top-color: #dc3545; }
                .stat-info { border-top-color: #17a2b8; }
                .chart-container {
                    background: white; border-radius: 12px; padding: 20px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 20px;
                }
                .chart-title { font-size: 1.1em; font-weight: bold; margin-bottom: 15px; color: #333; }
                .table-container {
                    background: white; border-radius: 12px; padding: 20px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 20px;
                }
            </style>

            <div class="dashboard-container">
                <h2 style="margin-bottom: 25px;">📊 Contract Dashboard</h2>

                <!-- KPI Cards Row 1 -->
                <div class="row mb-4">
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-primary">
                            <div class="stat-label">إجمالي العقود</div>
                            <div class="stat-value"><t t-esc="data['total_contracts']"/></div>
                            <div class="stat-label">هذا الشهر: <t t-esc="data['this_month']"/></div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-success">
                            <div class="stat-label">العقود النشطة</div>
                            <div class="stat-value"><t t-esc="data['active_contracts']"/></div>
                            <div class="stat-label">قيمة: <t t-esc="'{0:,.0f}'.format(data['active_value'])"/></div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-warning">
                            <div class="stat-label">مسودة</div>
                            <div class="stat-value"><t t-esc="data['draft_contracts']"/></div>
                            <div class="stat-label">تنتظر التأكيد</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-danger">
                            <div class="stat-label">منتهية الصلاحية</div>
                            <div class="stat-value"><t t-esc="data['expired_contracts']"/></div>
                            <div class="stat-label">تحتاج تجديد</div>
                        </div>
                    </div>
                </div>

                <!-- KPI Cards Row 2 -->
                <div class="row mb-4">
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-info">
                            <div class="stat-label">تنتهي قريبًا</div>
                            <div class="stat-value"><t t-esc="data['expiring_soon']"/></div>
                            <div class="stat-label">خلال 30 يوم</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-primary">
                            <div class="stat-label">إجمالي القيمة</div>
                            <div class="stat-value" style="font-size:1.6em;"><t t-esc="'{0:,.0f}'.format(data['total_value'])"/></div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-success">
                            <div class="stat-label">تم تحصيله</div>
                            <div class="stat-value" style="font-size:1.6em;"><t t-esc="'{0:,.0f}'.format(data['total_invoiced'])"/></div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card stat-danger">
                            <div class="stat-label">أقساط متأخرة</div>
                            <div class="stat-value"><t t-esc="data['overdue_installments']"/></div>
                            <div class="stat-label">تحتاج متابعة</div>
                        </div>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="chart-container">
                            <div class="chart-title">📍 العقود حسب الحالة</div>
                            <canvas id="stateChart" height="300"></canvas>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="chart-container">
                            <div class="chart-title">📈 العقود الشهرية (آخر 12 شهر)</div>
                            <canvas id="monthlyChart" height="150"></canvas>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="chart-container">
                            <div class="chart-title">⏰ الجدول الزمني للانتهاء</div>
                            <canvas id="expiryChart" height="200"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="table-container">
                            <div class="chart-title">🏆 أكبر العملاء</div>
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>العميل</th>
                                        <th>إجمالي العقود</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="top_partners" t-as="partner" t-as-index="idx">
                                        <tr>
                                            <td><t t-esc="idx + 1"/></td>
                                            <td><t t-esc="partner['name']"/></td>
                                            <td><t t-esc="'{0:,.2f}'.format(partner['total'])"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="not top_partners">
                                        <tr><td colspan="3" class="text-center text-muted">لا توجد بيانات</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                // State Chart (Doughnut)
                new Chart(document.getElementById('stateChart'), {
                    type: 'doughnut',
                    data: {
                        labels: <t t-esc="json.dumps([s.get('state','').title() for s in by_state])"/>,
                        datasets: [{
                            data: <t t-esc="json.dumps([s.get('count',0) for s in by_state])"/>,
                            backgroundColor: [
                                '#6c757d', // draft
                                '#17a2b8', // confirmed
                                '#ffc107', // financial
                                '#fd7e14', // legal
                                '#28a745', // finished
                                '#dc3545', // cancelled
                            ]
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });

                // Monthly Chart (Bar)
                new Chart(document.getElementById('monthlyChart'), {
                    type: 'bar',
                    data: {
                        labels: <t t-esc="json.dumps([m.get('month','') for m in by_month])"/>,
                        datasets: [{
                            label: 'Contracts',
                            data: <t t-esc="json.dumps([m.get('count',0) for m in by_month])"/>,
                            backgroundColor: '#1C5B8B',
                            borderRadius: 6,
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });

                // Expiry Timeline Chart (Bar)
                new Chart(document.getElementById('expiryChart'), {
                    type: 'bar',
                    data: {
                        labels: ['Expired', 'Next 7 Days', 'Next 30 Days', 'Next 90 Days', '90+ Days'],
                        datasets: [{
                            data: [
                                <t t-esc="expiry_timeline.get('expired', 0)"/>,
                                <t t-esc="expiry_timeline.get('next_7_days', 0)"/>,
                                <t t-esc="expiry_timeline.get('next_30_days', 0)"/>,
                                <t t-esc="expiry_timeline.get('next_90_days', 0)"/>,
                                <t t-esc="expiry_timeline.get('more_than_90', 0)"/>
                            ],
                            backgroundColor: ['#dc3545', '#ffc107', '#fd7e14', '#28a745', '#1C5B8B'],
                            borderRadius: 6,
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });
            </script>
        </t>
    </template>
</odoo>
